# Ignore everything
/*

# Allow main folders
!/src/
!/support/
!/tests/
!/include/
!/visualize
# Allow root files
!CMakeLists.txt
!.gitignore
!.clang-format
!.vscode/

# Ignore everything inside test output folders first
/tests/ex/*
/tests/im/*
/tests/cilk5/im/*
/tests/cilk5/ex/*

/tests/ex copy
/visualize/ir.json
/visualize/output.png
# # Re-allow only what you want to keep
!/tests/ex/*.cpp
!/tests/ex/*.c
!/tests/ex/*.sh
!/tests/ex/*hh
!/tests/im/*.cpp
!/tests/im/*.sh
!/tests/im/*.c
!/tests/cilk5/im/*.c
!/tests/cilk5/im/*h
!/tests/cilk5/im/*.cpp
!/tests/cilk5/ex/*.c
!/tests/cilk5/ex/*h
!/tests/cilk5/ex/*.cpp