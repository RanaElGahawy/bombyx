# Ignore everything
/*

# Allow main folders
!/src/
!/support/
!/tests/
!/include/
!/visualize
# Allow root files
!CMakeLists.txt
!.gitignore
!.clang-format
!.vscode/

# Ignore everything inside test output folders first
/tests/ex/*
/tests/im/*

/tests/ex copy
/visualize/ir.json
/visualize/output.png
# # Re-allow only what you want to keep
!/tests/ex/*.cpp
!/tests/ex/*.c
!/tests/ex/*.sh
!/tests/ex/*hh
!/tests/im/*.cpp
!/tests/im/*.sh
!/tests/im/*.c
tests/im/test_5.cpp
tests/im/test_6.cpp
tests/im/test_7.cpp
tests/im/test_8.cpp
